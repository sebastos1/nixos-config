{
    "layer": "top",
    "position": "bottom",
    "margin-left": 10,
    "margin-right": 10,
    "margin-bottom": 7,
    "margin-top": 0,
    "spacing": 10,
    "reload_style_on_change": true,
    "modules-left": [
        "sway/workspaces",
        "wlr/taskbar"
    ],
    "modules-center": [],
    "modules-right": [
        "tray",
        "custom/keybinds",
        "custom/mullvad",
        "custom/spacer",
        "memory",
        "cpu",
        "pulseaudio",
        "custom/spacer",
        "clock"
    ],
    "sway/workspaces": {
        "format": "{icon}",
        "format-icons": {
            "default": "",
            "focused": ""
        }
    },
    "wlr/taskbar": {
        "format": "{icon} {title:.20}",
        "icon-size": 22,
        "on-click": "activate",
        "on-click-right": "close",
        "tooltip-format": "{title}",
        "ignore-list": []
    },
    "custom/keybinds": {
        "format": "󰌌 Keys",
        "on-click": "~/.config/sway/keys.sh"
    },
    "custom/mullvad": {
        "format": "{}",
        "exec": "~/.config/sway/mullvad-check.sh",
        "return-type": "json",
        "interval": 10
    },
    "memory": {
        "interval": 1,
        "format": " {used}G",
        "on-click": "ghostty -e htop"
    },
    "cpu": {
        "interval": 1,
        "format": " {usage}%",
        "on-click": "ghostty -e htop"
    },
    "pulseaudio": {
        "format": "{icon} {volume}%",
        "format-muted": "󰝟 muted",
        "format-icons": {
            "default": [
                "󰕿",
                "󰖀",
                "󰕾"
            ]
        },
        "on-click": "pavucontrol",
        "on-scroll-up": "wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%+",
        "on-scroll-down": "wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%-",
        "smooth-scrolling-threshold": 1
    },
    "custom/date": {
        "format": "{}",
        "exec": "date '+%d/%m'",
        "interval": 60
    },
    "clock": {
        "format": "{:%d/%m %H:%M:%S}",
        "interval": 1
    },
    "custom/spacer": {
        "format": "|"
    },
    "tray": {
        "icon-size": 16
    }
}