{
    "layer": "top",
    "position": "bottom",
    "spacing": 0,
    "modules-left": [
        "sway/workspaces",
        "wlr/taskbar"
    ],
    "modules-center": [],
    "modules-right": [
        "custom/keybinds",
        "custom/mullvad",
        "cpu",
        "pulseaudio",
        "clock"
    ],
    "sway/workspaces": {
        "format": "{name}",
        "disable-scroll": true
    },
    "wlr/taskbar": {
        "format": "{icon} {title:.20}",
        "icon-size": 22,
        "on-click": "activate",
        "on-click-right": "close",
        "tooltip-format": "{title}",
        "ignore-list": []
    },
    "custom/keybinds": {
        "format": "⌨",
        "on-click": "~/.config/sway/keys.sh",
        "tooltip": false
    },
    "custom/mullvad": {
        "format": "{}",
        "exec": "~/.config/sway/mullvad-check.sh",
        "return-type": "json",
        "interval": 10,
        "tooltip": false
    },
    "cpu": {
        "interval": 1,
        "format": "󰻠 {usage}%",
        "on-click": "ghostty -e htop"
    },
    "pulseaudio": {
        "format": "{icon} {volume}%",
        "format-muted": "󰝟 muted",
        "format-icons": {
            "default": [
                "󰕿",
                "󰖀",
                "󰕾"
            ]
        },
        "on-click": "pavucontrol",
        "on-scroll-up": "wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%+",
        "on-scroll-down": "wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%-",
        "smooth-scrolling-threshold": 1
    },
    "custom/date": {
        "format": "{}",
        "exec": "date '+%d/%m'",
        "interval": 60,
        "tooltip": false
    },
    "clock": {
        "format": "{:%d/%m  %H:%M:%S}",
        "interval": 1,
        "tooltip": false
    }
}