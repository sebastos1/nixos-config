# win key
set $mod Mod4
bindsym $mod+Return exec ghostty
bindsym $mod+d exec rofi -show drun

# sway shit
bindsym $mod+Shift+c reload
bindsym $mod+Shift+r restart

bar {
    swaybar_command waybar
}

input * {
    xkb_layout "no"
    xkb_variant nodeadkeys
    accel_profile flat
    middle_emulation disabled
}


# monitors
output DP-3 resolution 1920x1200 position 0,0
output DP-2 resolution 1920x1080 position 1920,0
output HDMI-A-1 resolution 1680x1050 position 3840,0


# window management
# close
bindsym $mod+w kill

set $left j
set $right l
set $down k
set $up i

# focus
bindsym $mod+$left focus left
bindsym $mod+$right focus right
bindsym $mod+$down focus down
bindsym $mod+$up focus up

# move
bindsym $mod+Shift+$left move left
bindsym $mod+Shift+$right move right
bindsym $mod+Shift+$down move down
bindsym $mod+Shift+$up move up

# fullscreen
bindsym $mod+f fullscreen toggle

# Use Mouse+$mod to drag floating windows to their wanted position
floating_modifier $mod

# container layouts
bindsym $mod+h split h
bindsym $mod+v split v
bindsym $mod+t layout tabbed
bindsym $mod+e layout toggle split

# we ALL using ts
bindsym $mod+Shift+space floating toggle
bindsym $mod+space focus mode_toggle



# styling (gruvbox)
gaps inner 5
gaps outer 5
gaps bottom 0

set $bg #282828
set $fg #ebdbb2
set $border #928374
set $active #b4befe
set $inactive #3c3836
set $urgent #cc241d

client.focused          $active $active $fg $active $active
client.focused_inactive $inactive $inactive $fg $inactive $inactive
client.unfocused        $bg $bg $border $bg $bg
client.urgent           $urgent $urgent $fg $urgent $urgent

default_border pixel 2
default_floating_border pixel 2
hide_edge_borders smart
smart_gaps on
